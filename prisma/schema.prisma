generator client {
  provider = "prisma-client-js"
   binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id           String         @id @default(cuid())
  email        String         @unique
  nombre       String
  passwordHash String
  activo       Boolean        @default(true)
  creadoEn     DateTime       @default(now())
  actualizadoEn DateTime      @updatedAt
  roles        UsuarioRol[]
  permisosExtra UsuarioPermiso[]
  sesionesApertura SesionCaja[] @relation("UsuarioApertura")
  cajasAsignadas   Caja[]       @relation("CajaAsignada")
  movimientos  MovimientoInventario[]
  ventas       Venta[]
  ventasCanceladas Venta[]    @relation("UsuarioCancelacion")
  tokensSolicitados AutorizacionToken[] @relation("TokenSolicitante")
  tokensAutorizados AutorizacionToken[] @relation("TokenAutorizador")
  auditoriasSolicitadas AuditoriaAccion[] @relation("AuditoriaSolicitante")
  auditoriasAutorizadas AuditoriaAccion[] @relation("AuditoriaAutorizador")

  @@map("usuarios")
}

model Rol {
  id          String       @id @default(cuid())
  nombre      String       @unique
  descripcion String?
  usuarios    UsuarioRol[]
  permisos    RolPermiso[]
  creadoEn    DateTime     @default(now())

  @@map("roles")
}

model Permiso {
  id          String       @id @default(cuid())
  nombre      String       @unique
  descripcion String?
  roles       RolPermiso[]
  usuarios    UsuarioPermiso[]
  creadoEn    DateTime     @default(now())

  @@map("permisos")
}

model UsuarioRol {
  usuarioId String
  rolId     String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  rol       Rol      @relation(fields: [rolId], references: [id], onDelete: Cascade)
  asignadoEn DateTime @default(now())

  @@id([usuarioId, rolId])
  @@map("usuario_roles")
}

model RolPermiso {
  rolId     String
  permisoId String
  rol       Rol     @relation(fields: [rolId], references: [id], onDelete: Cascade)
  permiso   Permiso @relation(fields: [permisoId], references: [id], onDelete: Cascade)
  asignadoEn DateTime @default(now())

  @@id([rolId, permisoId])
  @@map("rol_permisos")
}

model UsuarioPermiso {
  usuarioId String
  permisoId String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  permiso   Permiso  @relation(fields: [permisoId], references: [id], onDelete: Cascade)
  asignadoEn DateTime @default(now())

  @@id([usuarioId, permisoId])
  @@map("usuario_permisos")
}

model AutorizacionToken {
  id            String    @id @default(cuid())
  token         String    @unique @default(cuid())
  accion        String
  targetId      String?
  solicitanteId String
  autorizadorId String
  motivo        String
  usadoEn       DateTime?
  expiraEn      DateTime
  creadoEn      DateTime  @default(now())
  solicitante   Usuario   @relation("TokenSolicitante", fields: [solicitanteId], references: [id])
  autorizador   Usuario   @relation("TokenAutorizador", fields: [autorizadorId], references: [id])

  @@map("autorizacion_tokens")
}

model AuditoriaAccion {
  id            String    @id @default(cuid())
  accion        String
  solicitanteId String
  autorizadorId String?
  targetId      String?
  motivo        String
  sucursalId    String?
  cajaId        String?
  // Stores item detail for eliminar_item_carrito actions (productoId, sku, nombre, cantidad, precioUnitario, subtotal, sesionCajaId)
  detalle       Json?
  creadoEn      DateTime  @default(now())
  solicitante   Usuario   @relation("AuditoriaSolicitante", fields: [solicitanteId], references: [id])
  autorizador   Usuario?  @relation("AuditoriaAutorizador", fields: [autorizadorId], references: [id])

  @@map("auditoria_acciones")
}

model ConfiguracionSistema {
  id    String @id @default(cuid())
  clave String @unique
  valor String
  creadoEn DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@map("configuracion_sistema")
}

model Sucursal {
  id        String   @id @default(cuid())
  nombre    String
  direccion String?
  activo    Boolean  @default(true)
  creadoEn  DateTime @default(now())
  cajas     Caja[]

  @@map("sucursales")
}

model Caja {
  id                String      @id @default(cuid())
  nombre            String
  sucursalId        String
  activo            Boolean     @default(true)
  usuarioAsignadoId String?
  creadoEn          DateTime    @default(now())
  sucursal          Sucursal    @relation(fields: [sucursalId], references: [id])
  usuarioAsignado   Usuario?    @relation("CajaAsignada", fields: [usuarioAsignadoId], references: [id])
  sesiones          SesionCaja[]

  @@map("cajas")
}

model SesionCaja {
  id             String    @id @default(cuid())
  cajaId         String
  usuarioAperturaId String
  fechaApertura  DateTime  @default(now())
  montoInicial   Decimal   @db.Decimal(10, 2)
  fechaCierre    DateTime?
  montoContado   Decimal?  @db.Decimal(10, 2)
  diferencia     Decimal?  @db.Decimal(10, 2)
  observaciones  String?
  estado         EstadoSesion @default(ABIERTA)
  // Corte Z summary totals (populated on close)
  totalVentas        Decimal? @db.Decimal(10, 2)
  totalEfectivo      Decimal? @db.Decimal(10, 2)
  totalTarjeta       Decimal? @db.Decimal(10, 2)
  totalTransferencia Decimal? @db.Decimal(10, 2)
  totalIva           Decimal? @db.Decimal(10, 2)
  totalIeps          Decimal? @db.Decimal(10, 2)
  caja           Caja      @relation(fields: [cajaId], references: [id])
  usuarioApertura Usuario  @relation("UsuarioApertura", fields: [usuarioAperturaId], references: [id])
  ventas         Venta[]

  @@map("sesiones_caja")
}

enum EstadoSesion {
  ABIERTA
  CERRADA
}

model Producto {
  id           String         @id @default(cuid())
  nombre       String
  codigoBarras String?        @unique
  tipoVenta    TipoVenta      @default(PIEZA)
  costoActual  Decimal        @db.Decimal(10, 2)
  margen       Decimal        @db.Decimal(5, 2)
  precioVenta  Decimal        @db.Decimal(10, 2)
  ivaAplica    Boolean        @default(true)
  iepsAplica   Boolean        @default(false)
  iepsPorcentaje Decimal      @default(0) @db.Decimal(5, 2)
  activo       Boolean        @default(true)
  creadoEn     DateTime       @default(now())
  actualizadoEn DateTime      @updatedAt
  inventario   Inventario?
  movimientos  MovimientoInventario[]
  ventaDetalles VentaDetalle[]

  @@map("productos")
}

enum TipoVenta {
  PIEZA
  CAJA
  GRANEL
}

model Inventario {
  id         String   @id @default(cuid())
  productoId String   @unique
  cantidad   Decimal  @db.Decimal(10, 3)
  actualizadoEn DateTime @updatedAt
  producto   Producto @relation(fields: [productoId], references: [id])

  @@map("inventario")
}

model MovimientoInventario {
  id         String       @id @default(cuid())
  productoId String
  tipo       TipoMovimiento
  cantidad   Decimal      @db.Decimal(10, 3)
  motivo     String?
  usuarioId  String?
  ventaId    String?
  creadoEn   DateTime     @default(now())
  producto   Producto     @relation(fields: [productoId], references: [id])
  usuario    Usuario?     @relation(fields: [usuarioId], references: [id])
  venta      Venta?       @relation(fields: [ventaId], references: [id])

  @@map("movimientos_inventario")
}

enum TipoMovimiento {
  ENTRADA
  SALIDA
  AJUSTE
}

enum EstadoVenta {
  COMPLETADA
  CANCELADA
}

enum MetodoPago {
  EFECTIVO
  TARJETA
  TRANSFERENCIA
}

model Venta {
  id             String       @id @default(cuid())
  folio          Int          @unique @default(autoincrement())
  sesionCajaId   String
  usuarioId      String
  metodoPago     MetodoPago   @default(EFECTIVO)
  subtotal       Decimal      @db.Decimal(10, 2)
  totalIva       Decimal      @db.Decimal(10, 2)
  totalIeps      Decimal      @db.Decimal(10, 2)
  total          Decimal      @db.Decimal(10, 2)
  pagoCon        Decimal?     @db.Decimal(10, 2)
  cambio         Decimal?     @db.Decimal(10, 2)
  // Payment metadata — populated based on metodoPago
  banco          String?      // TRANSFERENCIA: bank name
  referencia     String?      // TRANSFERENCIA: reference / clave de rastreo
  ultimos4       String?      // TARJETA: last 4 digits
  numeroOperacion String?     // TARJETA: operation/authorization number
  estado         EstadoVenta  @default(COMPLETADA)
  // Cancellation metadata
  canceladoEn    DateTime?
  canceladoPorId String?
  motivoCancelacion String?
  creadoEn       DateTime     @default(now())
  sesionCaja     SesionCaja   @relation(fields: [sesionCajaId], references: [id])
  usuario        Usuario      @relation(fields: [usuarioId], references: [id])
  canceladoPor   Usuario?     @relation("UsuarioCancelacion", fields: [canceladoPorId], references: [id])
  detalles       VentaDetalle[]
  movimientos    MovimientoInventario[]

  @@map("ventas")
}

model VentaDetalle {
  id           String   @id @default(cuid())
  ventaId      String
  productoId   String
  cantidad     Decimal  @db.Decimal(10, 3)
  precioUnitario Decimal @db.Decimal(10, 2)
  subtotal     Decimal  @db.Decimal(10, 2)
  ivaUnitario  Decimal  @db.Decimal(10, 2)
  iepsUnitario Decimal  @db.Decimal(10, 2)
  total        Decimal  @db.Decimal(10, 2)
  venta        Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  producto     Producto @relation(fields: [productoId], references: [id])

  @@map("venta_detalles")
}

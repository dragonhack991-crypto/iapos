# Dependencies - critical: prevents invalid file request errors on Windows paths
node_modules
**/node_modules

# Next.js build output
.next
**/.next
out

# Version control
.git
.gitignore

# Docker config files (not needed in build context)
Dockerfile*
docker-compose*.yml

# Environment files (secrets must not be baked into the image)
.env
.env.*
*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Build artifacts
dist
build
coverage

# OS / editor artifacts
.DS_Store
*.pem
.vscode
.idea
